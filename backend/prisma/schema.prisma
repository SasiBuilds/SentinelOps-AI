// =============================================================================
// SentinelOps AI – Prisma Schema (PostgreSQL)
// Single source of truth for every database model.
//
// Commands:
//   npm run db:generate        – regenerate Prisma client after schema changes
//   npm run db:migrate         – create & apply migration (dev)
//   npm run db:migrate:prod    – deploy pending migrations (CI / prod)
//   npm run db:studio          – open Prisma Studio GUI
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Enums
// =============================================================================

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum RecoveryAction {
  RESTART
  SCALE_UP
  SCALE_DOWN
  FAILOVER
  ROLLBACK
  NOTIFY
  MANUAL
}

enum RecoveryStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  FAILED
  SKIPPED
}

enum AlertStatus {
  FIRING
  RESOLVED
  SILENCED
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

// =============================================================================
// Models
// =============================================================================

// -----------------------------------------------------------------------------
// User – platform users with role-based access
// -----------------------------------------------------------------------------
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  passwordHash String    @map("password_hash")
  role         UserRole  @default(VIEWER)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Refresh tokens issued to this user
  refreshTokens RefreshToken[]
  // Incidents this user acknowledged / resolved
  incidents     Incident[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// -----------------------------------------------------------------------------
// RefreshToken – JWT refresh token store for rotation
// -----------------------------------------------------------------------------
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// -----------------------------------------------------------------------------
// Alert – raw alert events ingested from Prometheus / CloudWatch / custom
// -----------------------------------------------------------------------------
model Alert {
  id          String      @id @default(uuid())
  alertname   String
  severity    Severity    @default(MEDIUM)
  status      AlertStatus @default(FIRING)
  source      String?     // originating system (Prometheus, CloudWatch, etc.)
  service     String?     // affected service name
  namespace   String?     // Kubernetes namespace / AWS region
  labels      Json?       // arbitrary key-value labels from the alert
  annotations Json?       // arbitrary annotations
  startsAt    DateTime    @default(now()) @map("starts_at")
  endsAt      DateTime?   @map("ends_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Each alert may generate at most one incident (after deduplication)
  incident    Incident?   @relation(fields: [incidentId], references: [id])
  incidentId  String?     @map("incident_id")

  @@index([alertname])
  @@index([status])
  @@index([severity])
  @@index([service])
  @@index([startsAt])
  @@map("alerts")
}

// -----------------------------------------------------------------------------
// Incident – correlated, de-duplicated incidents derived from alerts
// -----------------------------------------------------------------------------
model Incident {
  id          String         @id @default(uuid())
  title       String
  description String?        @db.Text
  severity    Severity       @default(MEDIUM)
  status      IncidentStatus @default(OPEN)
  source      String?        // originating system
  service     String?        // affected service name
  region      String?        // AWS region / k8s namespace
  rootCause   String?        @map("root_cause") @db.Text
  resolvedAt  DateTime?      @map("resolved_at")
  detectedAt  DateTime       @default(now()) @map("detected_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // User who acknowledged or resolved this incident
  assigneeId  String?        @map("assignee_id")
  assignee    User?          @relation(fields: [assigneeId], references: [id])

  // Recovery actions taken for this incident
  recoveries  Recovery[]
  // Raw alerts that triggered this incident
  alerts      Alert[]

  @@index([status])
  @@index([severity])
  @@index([service])
  @@index([detectedAt])
  @@map("incidents")
}

// -----------------------------------------------------------------------------
// Recovery – automated or manual recovery action record
// -----------------------------------------------------------------------------
model Recovery {
  id          String         @id @default(uuid())
  incidentId  String         @map("incident_id")
  action      RecoveryAction
  status      RecoveryStatus @default(PENDING)
  automated   Boolean        @default(true)
  targetService String?      @map("target_service") // which service was acted upon
  output      String?        @db.Text
  errorMessage String?       @map("error_message") @db.Text
  startedAt   DateTime       @default(now()) @map("started_at")
  completedAt DateTime?      @map("completed_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  incident    Incident       @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@index([status])
  @@index([action])
  @@map("recoveries")
}
