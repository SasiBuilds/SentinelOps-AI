{
  "name": "sentinelops-ai-backend",
  "version": "1.0.0",
  "description": "SentinelOps AI – Autonomous Disaster Detection & Recovery Platform – Backend API",
  "type": "module",
  "main": "server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node --env-file=.env --watch server.js",
    "start": "node --env-file=.env server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "db:seed": "node --env-file=.env prisma/seed.js",
    "lint": "eslint src/ server.js",
    "format": "prettier --write \"src/**/*.js\" server.js"
  },
  "dependencies": {
    "@prisma/client": "5.14.0",
    "bcryptjs": "2.4.3",
    "compression": "^1.8.1",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "^4.22.2",
    "express-validator": "^7.3.2",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.2",
    "morgan": "^1.11.0",
    "swagger-ui-express": "5.0.1",
    "winston": "3.13.0"
  },
  "devDependencies": {
    "prisma": "5.14.0"
  },
  "prisma": {
    "seed": "node --env-file=.env prisma/seed.js"
  },
  "keywords": [
    "sentinelops",
    "disaster-recovery",
    "autonomous",
    "aws",
    "nodejs",
    "express",
    "postgresql"
  ],
  "author": "SentinelOps AI Team",
  "license": "MIT"
}