# =============================================================================
# SentinelOps AI – sentinel-ai service environment variables
# Copy to .env and fill in values.
# =============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Path to the incidents JSON file (relative to repo root or absolute)
INCIDENTS_FILE=../docs/incidents.json

# Lock timeout in seconds for concurrent incident writes
INCIDENTS_LOCK_TIMEOUT=5

# CORS origins – comma-separated list of allowed frontend/backend origins
CORS_ORIGINS=http://localhost:5173
